# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trade_tracker

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Webull OpenAPI
WEBULL_APP_KEY=your_app_key
WEBULL_APP_SECRET=your_app_secret
WEBULL_ENVIRONMENT=sandbox
# Auto-import open Webull positions into the trade journal (runs while the FastAPI process is up)
WEBULL_AUTO_SYNC_ENABLED=true
WEBULL_AUTO_SYNC_INTERVAL_HOURS=6
# Optional: force one Webull account_id; leave empty to use the first account from the API
WEBULL_SYNC_DEFAULT_ACCOUNT_ID=
WEBULL_SYNC_STRATEGY_NAME=webull_positions

# SwaggyStocks (for WSB sentiment dashboard)
SWAGGYSTOCKS_USERNAME=your_email
SWAGGYSTOCKS_PASSWORD=your_password
# ApeWisdom API requires no credentials

# Cloudflare
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ACCOUNT_ID=737e8715349674266a977fe6e53eb038

# Frontend (use the same host you use in the browser, e.g. http://127.0.0.1:8000 if you use 127.0.0.1 for Next)
NEXT_PUBLIC_API_URL=http://localhost:8000
